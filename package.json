{
  "name": "marp-template",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "scripts": {
    "build:html": "marp main.md --theme themes/marp.css --html --allow-local-files -o dist/main.html",
    "build:pdf": "marp main.md --theme themes/marp.css --pdf --allow-local-files -o dist/main.pdf",
    "build": "pnpm build:html && pnpm build:pdf",
    "preview": "marp main.md --theme themes/marp.css --html --allow-local-files -w -o dist/main.html",
    "server": "marp -s . --theme themes/marp.css --allow-local-files"
  },
  "devDependencies": {
    "@marp-team/marp-cli": "^4.2.3"
  }
}
